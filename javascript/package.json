  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dotmonk/wildling.git",
    "directory": "javascript"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^24.10.13",
    "typescript": "^5.9.3"
  }
}
