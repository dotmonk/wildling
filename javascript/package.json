{
  "name": "wildling",
  "version": "2.0.2",
  "private": true,
  "description": "Pattern based string generator library and CLI",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "wildling": "./bin/wildling"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "prepare": "sh scripts/prepare-package.sh",
