#!/bin/sh
DIR="$(cd "$(dirname "$0")" && pwd)"
DLL="$DIR/../dist/wildling.dll"
if [ ! -f "$DLL" ]; then
    echo "wildling dll not found. Run csharp/build.sh first." >&2
    exit 1
fi

if command -v dotnet >/dev/null 2>&1; then
    exec dotnet "$DLL" "$@"
fi

# No local runtime: reuse the .NET runtime image
exec docker run --rm \
    -v "$DIR/../dist:/dist:ro" \
    -v "$(pwd):/work" \
    -w /work \
    --network=host \
    mcr.microsoft.com/dotnet/runtime:8.0-alpine \
    dotnet /dist/wildling.dll "$@"
