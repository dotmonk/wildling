# Ecosystem mirror repos — copy to secrets / local env (never commit tokens).
#
# PHP and Swift mirrors. JavaScript publishes from javascript/ in the monorepo.

PHP_MIRROR_REPO=dotmonk/wildling-php
# PHP_MIRROR_TOKEN=

SWIFT_MIRROR_REPO=dotmonk/wildling-swift
# SWIFT_MIRROR_TOKEN=

# npm registry (optional): trusted publisher or NPM_TOKEN on dotmonk/wildling
# NPM_TOKEN=
