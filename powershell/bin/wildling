#!/bin/sh
DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$DIR/.." && pwd)"
ENTRY="$DIR/wildling.ps1"

if command -v pwsh >/dev/null 2>&1; then
    exec pwsh -NoProfile -File "$ENTRY" "$@"
fi

if command -v powershell >/dev/null 2>&1; then
    exec powershell -NoProfile -File "$ENTRY" "$@"
fi

# No local PowerShell: reuse the official image from build.sh
exec docker run --rm \
    -v "$ROOT:/app:ro" \
    -v "$(pwd):/work" \
    -w /work \
    --network=host \
    mcr.microsoft.com/powershell \
    pwsh -NoProfile -File /app/bin/wildling.ps1 "$@"
